# Copy this file to .env and fill in your own values.

# Port the Node server listens on
PORT=3000

# Public base URL of this server (used to build the certificate download link
# that Make.com fetches and attaches to the email). If you deploy this
# somewhere public, change this to that public URL, e.g. https://your-app.onrender.com
BASE_URL=http://localhost:3000

# The webhook URL from your Make.com scenario's "Webhook" trigger module.
# Leave this blank to run in local mail-simulation mode: certificates still
# generate for real and "deliver" themselves automatically ~24 hours after
# request (or instantly via the dev-deliver button below), with a line
# logged to this server's console standing in for the email Make.com would
# send. Fill this in once you've built the Make.com scenario (see README)
# to switch over to real Gmail delivery.
MAKE_WEBHOOK_URL=

# A long, random, secret string. Make.com's scenario calls this server back
# (via an HTTP module) once it has actually sent the Gmail email, and must
# send this same secret so we know the callback is legitimate. Generate one
# with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MAKE_CALLBACK_SECRET=change-this-to-a-long-random-string

# When true, exposes a "Mark delivered (dev/testing only)" button on the
# Internship page so you can see the full delivered/downloaded state without
# waiting for the real 24-hour Make.com delay. Set to false in production.
DEV_MODE=true
